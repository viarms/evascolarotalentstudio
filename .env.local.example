# Copy this to .env.local and fill in your values

# WordPress origin URL (before DNS is pointed to Vercel)
WP_ORIGIN=https://evascolarotalentstudio.com

# WPGraphQL endpoint (usually WP_ORIGIN + /graphql)
NEXT_PUBLIC_WP_GRAPHQL_URL=https://evascolarotalentstudio.com/graphql

# WhatsApp number (international format, no + or spaces)
NEXT_PUBLIC_WA_NUMBER=6282146284464

# WordPress admin credentials for seeding content (scripts/seed-classes.mjs)
# Use an Application Password, NOT your main password.
# Create one at: WP Admin → Users → Edit your user → Application Passwords
WP_ADMIN_USER=your_wp_username
WP_ADMIN_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Google Analytics & Tag Manager ──────────────────────────────────────────
# Google Tag Manager container ID
NEXT_PUBLIC_GTM_ID=GTM-NKCTQ2DW
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-1JDY0MTPSV
# Google Tag ID (connected tag — fired via GTM, no extra config needed here)
# GT-WF8DNWZW
